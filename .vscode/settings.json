{
    "C_Cpp.default.compilerArgs": [
        "-O2",
        "-std=c++14",
        "-Wall"
    ],
    "C_Cpp.default.compilerPath": "g++.exe",
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "code-runner.runInTerminal": true,
    "code-runner.executorMap": {
        "javascript": "node",
        "java": "cd $dir && javac $fileName && java $fileNameWithoutExt && del $fileNameWithoutExt.class",
        "c": "cd $dir && gcc $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "cpp": "cd $dir && g++ -fdiagnostics-color=always -O2 -std=c++14 -Wall $fileName -o $fileNameWithoutExt && echo \"编译成功\" && .\\$fileNameWithoutExt ",
        "php": "php",
        "python": "python -u",
        "perl": "perl",
        "perl6": "perl6",
        "ruby": "ruby",
        "go": "go run",
        "powershell": "powershell -ExecutionPolicy ByPass -File",
        "bat": "cmd /c",
        "fsharp": "fsi",
        "csharp": "scriptcs",
        "vbscript": "cscript //Nologo",
        "typescript": "ts-node",
        "pascal": "cd $dir && fpc $fileName && $dir$fileNameWithoutExt",
    },
    "php.validate.executablePath": "",
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "{hexdiff}:/**/*.*": "hexEditor.hexedit",
        "*.exe": "hexEditor.hexedit"
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false,
        "cpp": false,
        "java": false
    },
    "luogu.defaultLanguageVersion": {
        "C++": "C++23 with O2",
        "C": "C with O2",
        "Java": "Java 21",
        "Python": "Python 3"
    },
    "explorer.confirmDragAndDrop": false
}